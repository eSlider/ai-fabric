# Gitea container runtime
USER_UID=1000
USER_GID=1000
DOCKER_UID=1000
DOCKER_GID=1000
GITEA__actions__ENABLED=true
GITEA__database__DB_TYPE=sqlite3
GITEA__database__PATH=/data/gitea/gitea.db

# Gitea identity
GITEA__server__ROOT_URL=http://localhost:3000/
GITEA__server__SSH_DOMAIN=localhost

# Actions runner
GITEA_INSTANCE_URL=http://gitea:3000
GITEA_RUNNER_REGISTRATION_TOKEN=replace-with-runner-token
GITEA_RUNNER_NAME=ai-fabric-runner
CONFIG_FILE=/tmp/runner/config.yaml

# Gitea MCP service
GITEA_HOST=http://gitea:3000
GITEA_ACCESS_TOKEN=
GITEA_INSECURE=false

# Telegram bot control plane
TELEGRAM_BOT_NAME=trrrrmonexbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USERNAMES=
GITEA_BOT_BASE_URL=http://localhost:3000
GITEA_BOT_OWNER=eslider
GITEA_BOT_REPO=ai-fabric
GITEA_BOT_TOKEN=
GITEA_CLI_ENABLED=1
GITEA_CLI_BIN=
GITEA_CLI_IMAGE=gitea/tea:latest
GITEA_CLI_LOGIN=ai-fabric
GITEA_CLI_URL=http://localhost:3000
GITEA_CLI_TOKEN=
GITEA_CLI_DOCKER_NETWORK=host

# Issue handler automation
ISSUE_BASE_BRANCH=main
ISSUE_POLL_INTERVAL_SEC=45
ISSUE_MAX_FIX_ATTEMPTS=3
ISSUE_RETRY_INTERVAL_SEC=600
ISSUE_AGENT_BIN=agent
ISSUE_AGENT_EXTRA_ARGS=
ISSUE_HANDLER_DRY_RUN=0
ISSUE_ARCHITECT_ENABLED=1
ISSUE_ARCHITECT_MAX_CHARS=6000
ISSUE_HANDLER_TRIGGER_ON_CREATE=1
ISSUE_APPROVALS_FILE=var/issue-handler/approvals.json
CURSOR_SETTINGS_DIR=
CURSOR_CONFIG_DIR=
CURSOR_LOCAL_BIN_DIR=
CURSOR_AGENT_HOME_DIR=
CURSOR_API_KEY=
